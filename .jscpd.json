{
  "minLines": 5,
  "minTokens": 70,
  "reporters": ["console", "html"],
  "output": ".jscpd",
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "**/__tests__/**",
    "**/typed-router.d.ts",
    "**/components.d.ts",
    "**/.nuxt/**",
    "**/storybook-static/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml"
  ],
  "threshold": 5,
  "absolute": true,
  "gitignore": true,
  "blame": true,
  "format": [
    "typescript",
    "tsx",
    "javascript",
    "jsx",
    "vue",
    "css",
    "scss",
    "less"
  ],
  "verbose": true
}
